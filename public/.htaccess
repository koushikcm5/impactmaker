# ============================================
# J-Impact React SPA — Hostinger .htaccess
# ============================================

Options -MultiViews -Indexes

# ── MIME Types (Critical for module scripts) ─────────
<IfModule mod_mime.c>
  AddType application/javascript .js .mjs
  AddType text/css .css
  AddType image/svg+xml .svg
  AddType image/webp .webp
  AddType font/woff .woff
  AddType font/woff2 .woff2
  AddType application/json .json
  AddType application/ld+json .jsonld
</IfModule>

# ── Pre-compressed GZIP serving support ──────────────
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Serve pre-compressed .gz file if browser accepts it and the file exists
  RewriteCond %{HTTP:Accept-Encoding} gzip
  RewriteCond %{DOCUMENT_ROOT}/$1.gz -f
  RewriteRule ^(.*?)\.(js|css|html)$ $1.$2.gz [QSA,L]
</IfModule>

# Fix headers and content type for pre-compressed files
<IfModule mod_headers.c>
  <FilesMatch "\.js\.gz$">
    ForceType application/javascript
    Header set Content-Encoding gzip
  </FilesMatch>
  <FilesMatch "\.css\.gz$">
    ForceType text/css
    Header set Content-Encoding gzip
  </FilesMatch>
  <FilesMatch "\.html\.gz$">
    ForceType text/html
    Header set Content-Encoding gzip
  </FilesMatch>
</IfModule>

# ── SSL & Canonical Redirection (Fixes "Page with redirect") ──
<IfModule mod_rewrite.c>
  # 1. Force HTTPS
  RewriteCond %{HTTPS} !=on
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # 2. Force Canonical Domain (Redirect WWW to non-WWW)
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^(.*)$ https://%1/$1 [R=301,L]
</IfModule>

# ── React Router SPA Routing (Fixes 404 issues) ──────
<IfModule mod_rewrite.c>
  # Clean URL redirects for tools
  RewriteRule ^spinwheel/?$ /tools/spinwheel.html [L]
  RewriteRule ^thermometer/?$ /tools/thermometer.html [L]
  RewriteRule ^fitnessboard/?$ /tools/fitnessboard.html [L]
  RewriteRule ^3d/?$ /tools/3d.html [L]

  # Direct access to HTML tools in /tools/ directory
  RewriteCond %{REQUEST_URI} ^/tools/.*\.html$
  RewriteRule ^ - [L]

  # Don't rewrite if the file or directory exists
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # DO NOT fall back to index.html if an asset folder file is missing (serves clean 404)
  RewriteCond %{REQUEST_URI} !^/assets/.*$

  # Fallback all other requests to index.html for SPA React Routing
  RewriteRule ^ index.html [QSA,L]
</IfModule>

# ── Enable CORS ──────────────────────────────────────
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|svg)$">
    Header set Access-Control-Allow-Origin "*"
  </FilesMatch>
</IfModule>

# ── On-the-fly Compression (For non-pre-compressed files) ──
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/plain
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/xml
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE application/xml
  AddOutputFilterByType DEFLATE application/xhtml+xml
  AddOutputFilterByType DEFLATE application/rss+xml
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/x-javascript
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ── Browser Caching (Speed up loading, improve Lighthouse) ──
<IfModule mod_expires.c>
  ExpiresActive On
  
  # Hashed Vite assets cache for 1 year
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/css "access plus 1 year"
  
  # Images and fonts cache for 1 month
  ExpiresByType image/x-icon "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/gif "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"

  # Never cache index.html, sitemap, robots (essential for React updates)
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType application/xml "access plus 0 seconds"
  ExpiresByType text/plain "access plus 0 seconds"
</IfModule>
